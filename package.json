{
  "name": "personal-finance-agent",
  "version": "1.0.0",
  "description": "AI-powered personal finance tracking via Telegram",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "telegram",
    "bot",
    "finance",
    "ai",
    "gemini",
    "expense-tracker"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google": "^3.0.29",
    "@mastra/core": "^1.4.0",
    "@mastra/loggers": "^1.0.1",
    "@mastra/memory": "^1.3.0",
    "@mastra/mongodb": "^1.3.1",
    "@mastra/observability": "^1.2.0",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "dotenv": "^16.4.7",
    "grammy": "^1.30.0",
    "mongodb": "^6.12.0",
    "ollama-ai-provider-v2": "^3.3.0",
    "telegramify-markdown": "^1.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.18.0",
    "mastra": "^1.3.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
